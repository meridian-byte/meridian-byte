// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// npx prisma migrate dev --name init -> sync database
// npx prisma db push -> sync database
// npx prisma studio -> view database
// npx prisma generate -> generate prisma client

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // uses connection pooling
  directUrl = env("DIRECT_URL") // uses a direct connection
}

// enums

enum Role {
  USER
  ADMIN
  DEV
}

enum Status {
  ACTIVE
  INACTIVE
  DRAFT
  PUBLISHED
}

enum SyncStatus {
  PENDING
  SYNCED
  SAVED
  ERROR
  DELETED
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
}

enum AccountType {
  ASSET
  LIABILITY
}

enum CategoryType {
  BLOG
  CREDIT
  DEBIT
}

enum WorkspaceType {
  NOTELINE
  STRIDE
}

enum WeightUnitType {
  MILLIGRAMS
  GRAMS
}

enum EatTime {
  BREAKFAST
  LUNCH
  DINNER
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

enum Priority {
  URGENT_IMPORTANT
  NOT_URGENT_IMPORTANT
  URGENT_UNIMPORTANT
  NOT_URGENT_UNIMPORTANT
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
}

enum ViewType {
  LIST
  BOARD
  CALENDAR
}

enum GroupSort {
  PRIORITY
  CATEGORY
  DATE
}

enum SortDirection {
  ASCENDING
  DESCENDING
}

// models

model Profile {
  id         String  @id
  email      String
  user_name  String?
  first_name String?
  last_name  String?
  bio        String?
  avatar     String?
  phone      String?
  customized Boolean @default(false)
  role       Role    @default(USER)

  posts           Post[]
  comments        Comment[]
  categories      Category[]
  accountGroups   AccountGroup[]
  accounts        Account[]
  transactions    Transaction[]
  budgets         Budget[]
  food            Food[]
  meals           Meal[]
  servings        Serving[]
  eats            Eat[]
  masses          Mass[]
  notes           Note[]
  links           Link[]
  chats           Chat[]
  chat_messages   ChatMessage[]
  customizations  Customization[]
  tasks           Task[]
  reminders       Reminder[]
  views           View[]
  notifications   Notification[]
  recurring_rules RecurringRule[]
  workspaces      Workspace[]

  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([email])
  @@map("profiles")
}

model Post {
  id             String  @id @default(uuid())
  image          String
  title          String
  excerpt        String
  content        String
  allow_comments Boolean @default(true)
  view_count     Int     @default(0)

  profile     Profile?  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id  String?
  category    Category? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id String?

  comments Comment[]

  status      Status     @default(DRAFT)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([profile_id, title])
  @@map(name: "posts")
}

model Category {
  id                 String       @id @default(uuid())
  title              String
  parent_category_id String?
  type               CategoryType @default(BLOG)

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  posts        Post[]
  transactions Transaction[]
  budgets      Budget[]
  tasks        Task[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "categories")
}

model Workspace {
  id    String        @id @default(uuid())
  title String
  type  WorkspaceType

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  notes Note[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "workspaces")
}

model Comment {
  id         String  @id @default(uuid())
  name       String?
  content    String
  comment_id String?

  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  post_id    String
  profile    Profile? @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String?

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([name, content, post_id, profile_id])
  @@map(name: "comments")
}

model AccountGroup {
  id   String @id @default(cuid())
  name String // e.g., 'Bank Accounts', 'Savings', 'Credit Cards'

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  accounts Account[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "account_groups")
}

model Account {
  id            String      @id @default(cuid())
  name          String // e.g., 'Chase Checking', 'Wallet Cash'
  type          AccountType @default(ASSET)
  balance       Decimal     @default("0.00") @db.Decimal(18, 2)
  currency      String? // eg. Dollars, Euros, Shillings
  currency_code String? // eg. USD, EUR, KES
  description   String?

  profile    Profile      @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String
  group      AccountGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  group_id   String

  transactions Transaction[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "accounts")
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType @default(DEBIT)
  transfer    Boolean         @default(false)
  amount      Decimal         @default("0.00") @db.Decimal(8, 2)
  fees        Decimal         @default("0.00") @db.Decimal(8, 2)
  description String?

  profile           Profile        @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id        String
  account           Account        @relation(fields: [account_id], references: [id], onDelete: Cascade)
  account_id        String
  category          Category       @relation(fields: [category_id], references: [id], onDelete: Cascade)
  category_id       String
  recurring_rule    RecurringRule? @relation(fields: [recurring_rule_id], references: [id], onDelete: Cascade)
  recurring_rule_id String?

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "transactions")
}

model RecurringRule {
  id        String    @id @default(uuid())
  frequency Frequency
  interval  Int       @default(1)
  end_date  DateTime?
  weekdays  String[] // 0 - monday, 6 - sunday. comma separated for multiples. eg. 0,4,6
  months    String[] // 0 - january, 12 - december. comma separated for multiples. eg. 5,7,11
  end       DateTime?

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  transactions Transaction[]
  tasks        Task[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "recurring_rules")
}

model Budget {
  id    String   @id @default(cuid())
  limit Decimal  @default("0.00") @db.Decimal(8, 2)
  start DateTime // Start of the budget period (e.g., 2025-11-01)
  end   DateTime // End of the budget period (e.g., 2025-11-30)

  profile     Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id  String
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)
  category_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "budgets")
}

model Food {
  id          String         @id @default(cuid())
  name        String // eg. brand name
  description String? // eg. food type (whole brown bread)
  per         Int // eg. (100)
  per_unit    WeightUnitType // eg. (grams)
  carbs       Int
  protein     Int
  fat         Int
  kcal        Int

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  servings Serving[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "foods")
}

model Meal {
  id          String  @id @default(cuid())
  name        String
  description String?

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  servings Serving[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "meals")
}

model Serving {
  id           String         @id @default(cuid())
  serving_size Int // eg. (100)
  serving_unit WeightUnitType // eg. (grams)

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String
  food       Food    @relation(fields: [food_id], references: [id], onDelete: Cascade)
  food_id    String
  meal       Meal?   @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  meal_id    String?
  eat        Eat?    @relation(fields: [eat_id], references: [id], onDelete: Cascade)
  eat_id     String?

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "servings")
}

model Eat {
  id   String  @id @default(cuid())
  time EatTime

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  servings Serving[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "eats")
}

model Mass {
  id           String @id @default(cuid())
  weight       Int
  fat          Int
  visceral_fat Int
  lean_weight  Int
  muscle       Int
  bone         Int
  water        Int
  bmi          Int
  bmr          Int

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "masses")
}

model Note {
  id             String  @id @default(uuid())
  title          String
  content        String?
  parent_note_id String?

  profile      Profile    @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id   String
  workspace    Workspace? @relation(fields: [workspace_id], references: [id], onDelete: SetNull)
  workspace_id String?

  links_from Link[] @relation("FromLinks") // outgoing links
  links_to   Link[] @relation("ToLinks") // incoming links (backlinks)

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "notes")
}

model Link {
  id String @id @default(uuid())

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String
  from       Note    @relation("FromLinks", fields: [from_id], references: [id])
  from_id    String
  to         Note    @relation("ToLinks", fields: [to_id], references: [id])
  to_id      String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([from_id, to_id]) // avoid duplicate links
  @@map(name: "links")
}

model Chat {
  id        String  @id @default(uuid())
  title     String
  archived  Boolean @default(false)
  temporary Boolean @default(false)

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  messages ChatMessage[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("chats")
}

model ChatMessage {
  id      String          @id @default(uuid())
  role    ChatMessageRole
  content String
  sources String[]
  error   String?
  search  Boolean?

  chat       Chat    @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  chat_id    String
  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("chat_messages")
}

model Customization {
  id           String  @id @default(uuid())
  nickname     String?
  occupation   String?
  traits       String?
  partialities String?
  active       Boolean @default(false)

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("customizations")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  complete    Boolean   @default(false)
  description String?
  due_date    DateTime?
  priority    Priority  @default(NOT_URGENT_UNIMPORTANT)

  profile           Profile        @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id        String
  category          Category?      @relation(fields: [category_id], references: [id], onDelete: SetNull)
  category_id       String?
  recurring_rule    RecurringRule? @relation(fields: [recurring_rule_id], references: [id])
  recurring_rule_id String?

  reminders Reminder[]

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "tasks")
}

model Reminder {
  id        String   @id @default(uuid())
  remind_at DateTime
  sent      Boolean  @default(false)

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String
  task       Task    @relation(fields: [task_id], references: [id], onDelete: Cascade)
  task_id    String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "reminders")
}

model View {
  id              String         @id @default(uuid())
  title           String
  view            ViewType?      @default(LIST)
  sort_by         GroupSort?     @default(DATE)
  sort_direction  SortDirection? @default(DESCENDING)
  group_by        GroupSort?
  category_filter String?
  priority_filter Priority?

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "views")
}

model Notification {
  id             String  @id @default(uuid())
  endpoint       String
  endpointId     String
  expirationTime BigInt?
  p256dh         String
  auth           String

  profile    Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  profile_id String

  status      Status     @default(ACTIVE)
  sync_status SyncStatus @default(SYNCED)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map(name: "notifications")
}
